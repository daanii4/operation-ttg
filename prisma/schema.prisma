generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // List `public` first so Migrate uses `public._prisma_migrations` (shared ledger with Scholars OS).
  // TTG models live only in `ttg` — `scholars` is not listed, so the client cannot reference it.
  schemas   = ["public", "ttg"]
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum TargetDivision {
  DI
  DII
  DI_or_DII_undecided
  DIII
  NAIA
  Unknown

  @@schema("ttg")
}

enum RiskBand {
  GREEN
  YELLOW
  RED
  LOCKED
  NOT_APPLICABLE

  @@schema("ttg")
}

enum EvidenceTier {
  Deterministic
  Provisional
  Strong
  Moderate
  Weak
  Insufficient
  Not_Applicable

  @@schema("ttg")
}

enum UserRole {
  ADVISOR
  ADMIN

  @@schema("ttg")
}

/// Sprint 6 / Workstream C — multi-advisor team roles.
///
/// Layered over the legacy UserRole so existing single-advisor sessions stay
/// valid. The team role lives on AdvisorProfile (keyed by Supabase user id)
/// rather than on User because the production session identity is the
/// Supabase UUID, not the NextAuth User row.
enum AdvisorRole {
  owner
  advisor
  viewer

  @@schema("ttg")
}

enum CounselorEscalationAction {
  REFERRED_CLINICIAN
  PARENT_CONTACT
  CRISIS_PROTOCOL
  DOCUMENTED_ONLY
  OTHER

  @@schema("ttg")
}

enum NcaaChecklistItemKey {
  account_created
  ncaa_id_obtained
  official_transcript_sent
  amateurism_questionnaire_completed
  fee_waiver_applied_if_applicable

  @@schema("ttg")
}

// ─── USERS (NextAuth credential provider) ──────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ADVISOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  advisorStudents StudentAthlete[] @relation("AdvisorStudents")

  @@schema("ttg")
}

// ─── D2: DISTRICT ────────────────────────────────────────────────────────────

model District {
  id               String    @id @default(cuid())
  districtName     String
  state            String    @default("CA")
  /// UC A-G CMP district-level institution ID — enables one-pull multi-school A-G import
  ucDistrictId     String?
  lastVerifiedDate DateTime?
  sourceUrl        String?
  createdAt        DateTime  @default(now())

  schools HighSchool[]

  @@schema("ttg")
}

// ─── D2: HIGH SCHOOL (renamed from SchoolCalendar) ─────────────────────────────

model HighSchool {
  id String @id @default(cuid())

  district   District @relation(fields: [districtId], references: [id])
  districtId String

  schoolName      String
  /// 6-digit NCAA / College Board code
  ceebCode        String  @unique
  ucInstitutionId String?
  schoolCleared   Boolean @default(false)
  state           String  @default("CA")
  city            String?

  // ── Academic calendar (migrated from SchoolCalendar) ──
  seniorFallTermStart     DateTime?
  summerTermEnd           DateTime?
  maxCoresPerTerm         Int       @default(4)
  maxEmsPerTerm           Int       @default(2)
  calendarSourceUrl       String?
  creditRecoveryDeadlines Json?
  summerRegistrationClose DateTime?
  markingPeriodCloses     Json?
  lastCalendarVerified    DateTime?

  /// D2 §7 — school-specific course-name alias map (normalized key → canonical normalized)
  courseNameAliases Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students        StudentAthlete[]
  terms           SchoolTerm[]
  classifications CourseClassification[]

  @@schema("ttg")
}

model SchoolTerm {
  id           String     @id @default(cuid())
  highSchool   HighSchool @relation(fields: [highSchoolId], references: [id], onDelete: Cascade)
  highSchoolId String
  termName     String
  termType     String
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime   @default(now())

  @@schema("ttg")
}

// ─── D2: COURSE CLASSIFICATION CATALOG ───────────────────────────────────────

model CourseClassification {
  id String @id @default(cuid())

  highSchool      HighSchool @relation(fields: [highSchoolId], references: [id], onDelete: Cascade)
  highSchoolId    String
  ceebCode        String
  ucInstitutionId String?

  courseNameNormalized String
  courseNameDisplay    String
  academicYear         String

  ncaaD1Category        String?
  ncaaD2Category        String?
  ncaaApproved          Boolean @default(false)
  ncaaApprovedHonors    Boolean @default(false)
  countsGeometryForNcaa Boolean @default(false)

  agCategory            String?
  agApproved            Boolean @default(false)
  ucApprovedHonors      Boolean @default(false)
  countsLabForAg        Boolean @default(false)
  countsGeometryForAg   Boolean @default(false)
  agLanguageCode        String?
  preNinthGradeEligible Boolean @default(false)

  dataSourceClass  String   @default("B")
  lastVerifiedDate DateTime
  sourceUrl        String
  ingestionMethod  String
  verifiedBy       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([highSchoolId, courseNameNormalized, academicYear])
  @@index([highSchoolId, ncaaD1Category])
  @@index([highSchoolId, agCategory])
  @@index([highSchoolId, lastVerifiedDate])
  @@schema("ttg")
}

// ─── STUDENT ATHLETE ─────────────────────────────────────────────────────────

model StudentAthlete {
  id                   String         @id @default(cuid())
  firstName            String
  lastName             String
  grade                Int
  targetDivision       TargetDivision
  enrollmentDateGrade9 DateTime
  highSchoolId         String
  highSchoolName       String

  highSchool HighSchool? @relation(fields: [highSchoolId], references: [id])
  advisor    User?       @relation("AdvisorStudents", fields: [advisorId], references: [id])
  advisorId  String?

  courses                      CourseRecord[]
  f5Results                    F5Result[]
  compositeBandAcknowledgments CompositeBandAcknowledgment[]
  gradeUpdates                 GradeUpdate[]
  aimsAssessments              AimsAssessment[]
  engagementObservations       EngagementObservation[]
  ocrJobs                      OcrJob[]
  advisorAssignments           StudentAdvisorAssignment[]
  mlTrajectoryScores           MlTrajectoryScore[]
  classAFeedJobs               ClassAFeedJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advisorId])
  @@index([highSchoolId])
  @@schema("ttg")
}

model CompositeBandAcknowledgment {
  id                      String                     @id @default(uuid())
  student_id              String
  advisor_id              String
  band_transition         String
  acknowledged_at         DateTime                   @default(now())
  cryptographic_signature String
  conditions_snapshot     Json
  counselor_action        CounselorEscalationAction?
  counselor_notes         String?

  student StudentAthlete @relation(fields: [student_id], references: [id])

  @@index([student_id])
  @@map("composite_band_acknowledgments")
  @@schema("ttg")
}

// ─── COURSE RECORD ───────────────────────────────────────────────────────────

model CourseRecord {
  id                      String         @id @default(cuid())
  student                 StudentAthlete @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId               String
  courseName              String
  gradeLetterNormalized   String
  term                    String?
  termEndDate             DateTime
  termLength              String         @default("semester")
  academicYear            String?
  dataSourceClass         String         @default("B")
  ncaaD1Category          String?
  ncaaApproved            Boolean        @default(false)
  agCategory              String?
  classificationUpdatedAt DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  gradeUpdates            GradeUpdate[]

  @@index([studentId])
  @@schema("ttg")
}

model GradeUpdate {
  id                String   @id @default(uuid())
  student_id        String
  course_record_id  String
  observed_grade    String
  observed_at       DateTime
  data_source_class String
  advisor_id        String

  student      StudentAthlete @relation(fields: [student_id], references: [id])
  courseRecord CourseRecord   @relation(fields: [course_record_id], references: [id])

  @@index([student_id, observed_at])
  @@map("grade_updates")
  @@schema("ttg")
}

model AimsAssessment {
  id                         String   @id @default(uuid())
  student_id                 String
  social_identity_score      Float
  exclusivity_score          Float
  negative_affectivity_score Float
  administered_at            DateTime
  aims_version               String
  data_source_class          String

  student StudentAthlete @relation(fields: [student_id], references: [id])

  @@index([student_id, administered_at])
  @@map("aims_assessments")
  @@schema("ttg")
}

model EngagementObservation {
  id                String   @id @default(uuid())
  student_id        String
  observed_at       DateTime
  engagement_type   String
  value             Float
  raw_value         String?
  context           String?
  data_source_class String
  advisor_id        String

  student StudentAthlete @relation(fields: [student_id], references: [id])

  @@index([student_id, observed_at])
  @@map("engagement_observations")
  @@schema("ttg")
}

// ─── F5 RESULT ───────────────────────────────────────────────────────────────

model F5Result {
  id         String         @id @default(cuid())
  student    StudentAthlete @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  computedAt DateTime

  applicable          Boolean
  notApplicableReason String?

  lockInDate      DateTime?
  lockInDateBasis String?
  provisionalFlag Boolean   @default(false)
  daysToLock      Int?
  pastLock        Boolean   @default(false)

  completedTotal      Int @default(0)
  completedEngMathSci Int @default(0)
  missingTotal        Int @default(0)
  missingEngMathSci   Int @default(0)

  riskBand     RiskBand
  evidenceTier EvidenceTier

  agFailureDualFlags         Json @default("[]")
  unclassifiedCourseIds      Json @default("[]")
  recommendedCoursesNextTerm Json @default("[]")

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([computedAt])
  @@schema("ttg")
}

model NcaEligibilityChecklistState {
  id                              String   @id @default(cuid())
  studentId                       String
  accountCreated                  Boolean  @default(false)
  ncaaIdObtained                  Boolean  @default(false)
  officialTranscriptSent          Boolean  @default(false)
  amateurismQuestionnaireComplete Boolean  @default(false)
  feeWaiverAppliedIfApplicable    Boolean  @default(false)
  updatedByActorId                String?
  updatedAt                       DateTime @updatedAt
  createdAt                       DateTime @default(now())

  events NcaEligibilityChecklistEvent[]

  @@unique([studentId])
  @@index([studentId])
  @@schema("ttg")
}

model PdfExportJob {
  id         String   @id @default(uuid())
  advisor_id String
  job_type   String // 'student_briefing' | 'cohort_summary'
  status     String // 'pending' | 'generating' | 'ready' | 'failed'
  student_id String? // set for student_briefing type
  error      String?
  pdf_buffer Bytes? // stored as binary — cleared after 1 hour TTL
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([advisor_id, status])
  @@map("pdf_export_jobs")
  @@schema("ttg")
}

/// Sprint 6 / Workstream C — per-advisor profile + team role.
/// Keyed on the Supabase user UUID; created lazily on first dashboard load.
model AdvisorProfile {
  id           String      @id @default(uuid())
  advisor_id   String      @unique
  team_role    AdvisorRole @default(advisor)
  display_name String?
  email        String?
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  assignmentsAsAdvisor StudentAdvisorAssignment[]

  @@map("advisor_profiles")
  @@schema("ttg")
}

/// Sprint 6 / Workstream C — student↔advisor scoping.
model StudentAdvisorAssignment {
  id          String   @id @default(uuid())
  student_id  String
  advisor_id  String
  assigned_at DateTime @default(now())
  assigned_by String

  student StudentAthlete @relation(fields: [student_id], references: [id])
  advisor AdvisorProfile @relation(fields: [advisor_id], references: [advisor_id])

  @@unique([student_id, advisor_id])
  @@index([advisor_id])
  @@map("student_advisor_assignments")
  @@schema("ttg")
}

/// Sprint 6 / Workstream C — pending team invites.
model AdvisorInvite {
  id         String      @id @default(uuid())
  email      String
  role       AdvisorRole @default(advisor)
  invited_by String
  token      String      @unique
  accepted   Boolean     @default(false)
  created_at DateTime    @default(now())
  expires_at DateTime

  @@index([token])
  @@map("advisor_invites")
  @@schema("ttg")
}

model OcrJob {
  id                String   @id @default(uuid())
  advisor_id        String
  student_id        String
  status            String // 'pending' | 'processing' | 'needs_review' | 'accepted' | 'rejected' | 'failed'
  raw_text          String?  @db.Text
  parsed_courses    Json?
  accepted_courses  Json?
  confidence_scores Json?
  source_filename   String?
  error             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  student StudentAthlete @relation(fields: [student_id], references: [id])

  @@index([advisor_id, status])
  @@map("ocr_jobs")
  @@schema("ttg")
}

/// Sprint 7 / Workstream ML — per-student trajectory scores.
/// Advisory only — never overrides F8 composite band determination.
model MlTrajectoryScore {
  id               String   @id @default(uuid())
  student_id       String
  score            Float
  confidence_lower Float
  confidence_upper Float
  feature_vector   Json
  model_version    String
  risk_tier        String
  computed_at      DateTime @default(now())

  student StudentAthlete @relation(fields: [student_id], references: [id])

  @@index([student_id, computed_at])
  @@map("ml_trajectory_scores")
  @@schema("ttg")
}

/// Sprint 7 / Workstream ML — model training snapshots.
/// Outcome label is set at the time the snapshot is taken; weights are
/// retrained offline and bumped via a model_version change.
model MlTrainingSnapshot {
  id             String   @id @default(uuid())
  student_id     String
  feature_vector Json
  outcome        Boolean
  snapshot_date  DateTime
  model_version  String
  data_class     String

  @@index([model_version])
  @@map("ml_training_snapshots")
  @@schema("ttg")
}

/// Sprint 7 / Workstream A — Class A verified data feed ingestion jobs.
/// Disabled by default; only runs when DATA_FEED_ENABLED=true.
model ClassAFeedJob {
  id              String   @id @default(uuid())
  student_id      String
  provider        String
  status          String
  records_fetched Int?
  records_written Int?
  error           String?
  raw_payload     Bytes?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  student StudentAthlete @relation(fields: [student_id], references: [id])

  @@index([student_id, status])
  @@map("class_a_feed_jobs")
  @@schema("ttg")
}

/// Sprint 7 / Workstream T — calibrated thresholds.
/// Code reads via lib/config/thresholds.getThreshold(); never hardcodes.
model ThresholdConfig {
  id            String    @id @default(uuid())
  key           String
  value         Float
  description   String
  ticket        String
  conference    String?
  calibrated_by String?
  calibrated_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@unique([key, conference])
  @@index([key, conference])
  @@map("threshold_configs")
  @@schema("ttg")
}

model NcaEligibilityChecklistEvent {
  id            String                       @id @default(cuid())
  state         NcaEligibilityChecklistState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  stateId       String
  studentId     String
  itemKey       NcaaChecklistItemKey
  checked       Boolean
  actorId       String
  actorName     String?
  sourceContext String?
  previousHash  String?
  eventHash     String
  createdAt     DateTime                     @default(now())

  @@index([studentId, createdAt])
  @@index([stateId, createdAt])
  @@schema("ttg")
}
