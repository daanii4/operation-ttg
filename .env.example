# PostgreSQL (shared Supabase with scholars-os)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Supabase Auth (advisor sign-in)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
# Server-only — do not expose to the browser; optional for admin scripts
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Local dev without Supabase session (omit NEXT_PUBLIC_SUPABASE_* instead)
# TTG_DEV_USER_ID="admin-demo"
# TTG_DEV_USER_ROLE="ADMIN"
# TTG_ALLOW_ANONYMOUS_SESSION="true"

# D2 §10 — automated portal scraping (disabled until Agent 6 sign-off)
D2_AUTOMATED_INGESTION_ENABLED=false
